# Optional overrides. LibraForge runs with zero config — copy this to `.env`
# only when you want to change a default:
#
#   cp .env.example .env
#
# Run as your host user so bind-mounted files stay writable. `make up` sets these
# automatically; only set them here if you start with `docker compose` directly.
# UID=1000
# GID=1000

# Point these at your real audiobook library and a dedicated Audible auth directory.
# If unset, LibraForge uses the repo-local ./data/audiobooks and ./data/auth folders.
# AUDIOBOOKS_PATH=/path/to/audiobooks
# AUDIBLE_AUTH_PATH=/path/to/audible-auth
